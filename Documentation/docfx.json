{
  "metadata": [
    {
      "src": [
        {
          "src": "..",
          "files": [
            "/**/*.cs"
          ]
        }
      ],
      "globalNamespaceId": "Global",
      "filter": "filterConfig.yml",
      "dest": "api"
    }
  ],
  "build": {
    "globalMetadata": {
      "_appName": "SF Tool Documentation",
      "_appTitle": "SF Tool Documentation",
      "_enableSearch": true,
      "pdf": true
    },
    "content": ["**/*.md", "toc.yml"],
    "resource": [
      {
        "files": [
          "resources/**/*",
          "resources/images/*"
        ]
      }
    ],
    "template": [ "default", "templates/unity" ],
    "sitemap": {
      "baseUrl": "https://shatter-fantasy.github.io/SF-Metroidvania",
      "changefreq": "daily",
      "fileOptions": {
        "api/*": {
          "changefreq": "daily"
        }
      }
    },
    "xref": [ "https://normanderwan.github.io/UnityXrefMaps/xrefmap.yml" ],
    "xrefService": [
      "https://learn.microsoft.com/api/xref/query?uid={uid}"
    ],
    "dest": "../_site",
    "output": "../_site"
  }
}