{
  "metadata": [
    {
      "src": [
        {
          "src": "..",
          "files": [
            "/**/*.cs"
          ]
        }
      ],
      "globalNamespaceId": "Global",
      "filter": "filterConfig.yml",
      "dest": "api"
    }
  ],
  "build": {
    "globalMetadata": {
      "_appName": "SF Tool Documentation",
      "_appTitle": "SF Tool Documentation",
      "_enableSearch": true,
      "pdf": true
    },
    "content": [
      {
        "files": [
          "toc.yml",
          "index.md"
        ]
      },
      {
        "src": "api",
        "files": [
          "*.yml"
        ],
        "dest": "api"
      },
      {
        "src": "manual",
        "files": [
          "manual/**.md",
          "manual/**.toc.yml",
          "toc.yml",
          "*.md"
        ],
        "dest": "manual"
      },
      {
        "src": "manual/install-instructions",
        "files": [
          "toc.yml",
          "*.md"
        ],
        "dest": "manual/install-instructions"
      },
      {
        "src": "manual/physics-overview",
        "files": [
          "/**/toc.yml",
          "*.md",
          "/**/.md"
        ],
        "dest": "manual/physics-overview"
      },
      {
        "src": "manual/physics-overview/physics-core-2d",
        "files": [
          "toc.yml",
          "*.md",
          "/**/.md"
        ],
        "dest": "manual/physics-overview/physics-core-2d"
      },
      {
        "src": "manual/physics-overview/sf-physics-2d-module",
        "files": [
          "toc.yml",
          "*.md",
          "/**/.md"
        ],
        "dest": "manual/physics-overview/sf-physics-2d-module"
      }
    ],
    "resource": [
      {
        "files": [
          "resources/**/*",
          "resources/images/*"
        ]
      }
    ],
    "template": [ "default", "templates/unity" ],
    "sitemap": {
      "baseUrl": "https://shatter-fantasy.github.io/SF-Metroidvania",
      "changefreq": "daily",
      "fileOptions": {
        "api/*": {
          "changefreq": "daily"
        }
      }
    },
    "xref": [ "https://normanderwan.github.io/UnityXrefMaps/xrefmap.yml" ],
    "xrefService": [
      "https://learn.microsoft.com/api/xref/query?uid={uid}"
    ],
    "dest": "../_site",
    "output": "../_site"
  }
}